# PhynAI Agent Configuration
# Copy to .env and fill in your values: cp .env.example .env
#
# ROTATION: Rotate API keys regularly. To rotate:
#   1. Generate a new key at your provider's dashboard
#   2. Update the value below
#   3. Revoke the old key at the provider
# For production, use a secrets manager (Vault, AWS Secrets Manager, etc.)
# instead of this file. See: phynai setup

# ── LLM Provider ─────────────────────────────────────────────────────
PHYNAI_API_KEY=
PHYNAI_PROVIDER=anthropic
PHYNAI_MODEL=claude-opus-4-6

# Supported providers: anthropic, openai, openrouter, local
# Provider-specific keys (used as fallback if PHYNAI_API_KEY is empty):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# ── Gateway Tokens ───────────────────────────────────────────────────
# Telegram (reads PHYNAI_TELEGRAM_TOKEN or TELEGRAM_BOT_TOKEN)
TELEGRAM_BOT_TOKEN=
TELEGRAM_HOME_CHANNEL=
TELEGRAM_ALLOWED_USERS=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_HOME_CHANNEL=
DISCORD_ALLOWED_USERS=

# ── Web Search ──────────────────────────────────────────────────────
EXA_API_KEY=

# ── Paths & Logging ─────────────────────────────────────────────────
PHYNAI_SESSION_DIR=~/.phynai/sessions
PHYNAI_LOG_LEVEL=warning
